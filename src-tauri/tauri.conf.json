{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Etchy",
  "version": "0.1.0",
  "identifier": "app.etchy.Etchy",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Etchy — Verified ISO → USB Flasher",
        "width": 900,
        "height": 640,
        "minWidth": 780,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "theme": null
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": [],
    "category": "Utility",
    "shortDescription": "Verified ISO → USB flasher",
    "longDescription": "Etchy flashes ISO images to USB drives with mandatory read-back verification, live speed graphs, fake-drive detection and optional Linux persistence.",
    "linux": {
      "deb": {
        "depends": ["policykit-1"]
      }
    }
  }
}
